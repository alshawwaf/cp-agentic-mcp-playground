# ---------------- Postgres ----------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n
POSTGRES_PORT=5432

# ---------------- n8n ----------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_string
N8N_USER_MANAGEMENT_JWT_SECRET=change_me_to_a_random_secret

# admin/owner (the one we POST in provision)
N8N_ADMIN_EMAIL=admin@example.com
N8N_ADMIN_FIRST_NAME=Admin
N8N_ADMIN_LAST_NAME=User
N8N_ADMIN_PASSWORD=change_me

# basic auth (MUST match provisioner)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678/
N8N_PUSH_BACKEND=websocket

# Bearer token for the DevHub MCP endpoint (hub.<domain>/api/mcp). Substituted
# into the committed "DevHub Bearer Auth" credential at import time and must
# match the API key the dev-hub portal seeds from DEVHUB_MCP_TOKEN. Leave blank
# to skip importing the DevHub agent's credential. (PILOT_MCP_TOKEN, further
# down, is the equivalent for the PolicyPilot agent.)
DEVHUB_MCP_TOKEN=

# ---------------- Ollama ----------------
OLLAMA_PORT=11434
OLLAMA_HOST=localhost
OLLAMA_KEEP_ALIVE=-1
# Models pulled on startup (comma-separated). Roles: gemma4 = chat default,
# qwen3.5:9b = n8n agents (tool calling), mythos = Lakera attack target
# (uncensored), deepseek-r1 = reasoning demo, qwen3-embedding = RAG/Qdrant.
# Full demo list (heavy — GPU or patient CPU):
# OLLAMA_MODELS=gemma4:e2b,qwen3.5:9b,richardyoung/mythos-9b-unhinged-abliterated:latest,huihui_ai/deepseek-r1-abliterated:8b,qwen3-embedding:0.6b
# CPU-only default: small fast chat model + the best LIGHT tool-calling model.
OLLAMA_MODELS=gemma4:e2b,qwen3.5:4b
# RAM guard on CPU boxes: at most N models resident at once.
OLLAMA_MAX_LOADED_MODELS=2

# ---------------- Langflow / Flowise / Open-WebUI ----------------
LANGFLOW_PORT=7860
FLOWISE_PORT=3001
OPEN_WEBUI_PORT=3000
# Default model for new Open WebUI users/chats
OPEN_WEBUI_DEFAULT_MODELS=gemma4:e2b
# Langflow auth: true = no-login demo mode; false (default) = login required.
LANGFLOW_AUTO_LOGIN=false


# Documentation MCP creds
DOC_CLIENT_ID=
DOC_SECRET_KEY=
DOC_REGION=EU   # one of: EU, US, STG, Local


# SMS MCP Credentials
# MANAGEMENT_HOST must be reachable FROM THIS DOCKER HOST. For a CloudShare lab
# use the SMS adapter's CloudShare PUBLIC IP (Inbound Access: Public IP) — the
# internal lab IP (10.1.1.x) is not routable from outside the environment. Also
# make sure the SMS routes replies back out the CloudShare gateway (see
# docs/guides/MCP_Gateway_Agent_Guide.md, "Lab connectivity").
MANAGEMENT_HOST=
MANAGEMENT_API_KEY=
TE_API_KEY=
REPUTATION_API_KEY=
SPARK_MGMT_CLIENT_ID=
SPARK_MGMT_SECRET_KEY=
SPARK_MGMT_REGION=US
SPARK_MGMT_INFINITY_PORTAL_URL=https://cloudinfra-gw-us.portal.checkpoint.com/auth/external
HARMONY_SASE_API_KEY=
HARMONY_SASE_MANAGEMENT_HOST=
HARMONY_SASE_REGION=

CPINFO_LOG_LEVEL=info

# ---------------- Exercise: Build Your Own MCP Server (opt-in) ----------------
# Check Point Infinity Portal API key (Global Settings -> API Keys, IPS Info
# service) for the IPS/CVE exercise sidecar (profile: exercises).
# See docs/guides/Build_Your_Own_MCP_Exercise.md.
IPS_CLIENT_ID=
IPS_ACCESS_KEY=
# Optional region override — leave blank for the global host. Auth + service
# host MUST match (e.g. both cloudinfra-gw-us or both cloudinfra-gw-eu):
IPS_AUTH_URL=
IPS_SERVICE_URL=

# ---------------- PolicyPilot MCP sidecar (opt-in: profile `policypilot`) ----------------
# See docs/guides/PolicyPilot_Gateway_Sidecar_Guide.md. Requires a PolicyPilot
# image (its `mcp` dep installs via Artifactory) and a DB + key from the portal.
POLICYPILOT_IMAGE=policypilot:custom
PILOT_MCP_TOKEN=
# Must match the key the PolicyPilot portal used to encrypt saved SMS/gateway creds:
PILOT_ENCRYPTION_KEY=
# Point at the portal's DB (share its volume) for populated servers; default is an empty local DB:
PILOT_DATABASE_URL=sqlite:////data/policypilot.db

# ---------------- MCP Gateway (pilot) ----------------
# Stable Bearer token the Docker MCP Gateway requires from clients
# (Authorization: Bearer <token>). Pinning it keeps the provisioned n8n
# credential valid across redeploys; leaving it unset here falls back to the
# compose default used by the training credential. Override for real deployments.
MCP_GATEWAY_TOKEN=cp-mcp-gateway-training-token

# ---------------- LLM provider keys (n8n agent chat models) ----------------
# Bring-your-own. Any key you supply is injected into the matching n8n
# credential at import time, so that provider's Chat Model node works out of
# the box. Leave a key empty to skip that provider (its node stays on the
# canvas; set the key later in the n8n UI). Azure OpenAI is the default model
# wired to every agent.
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------- Integration credentials (set once, auto-injected) ----------------
# Injected into the matching n8n credential at every import — set them here (or
# in the installer's answers.env) ONCE and never touch the n8n UI again.
# Lakera Guard (external SaaS key from platform.lakera.ai) — guarded-chat demos:
LAKERA_API_KEY=
# Bearer token the SCIM identity agent sends to the Identity Provider (IdP)
# (must match the token configured in the simulator):
SCIM_IDP_TOKEN=
# Qdrant API key (leave empty — the bundled Qdrant runs without auth on the
# internal network; set only if you enable Qdrant auth):
QDRANT_API_KEY=

# ---------------- AI-Infra-Guard (AI Red Teaming) ----------------
AIG_PORT=8088
# LLM for MCP scanning & jailbreak eval (defaults to local Ollama)
AIG_LLM_API_KEY=ollama
AIG_LLM_BASE_URL=http://ollama-cpu:11434/v1
# Must be one of the pulled OLLAMA_MODELS tags (see above)
AIG_LLM_MODEL=huihui_ai/deepseek-r1-abliterated:8b

# ---------------- Compose profiles ----------------
# The core CPU stack (n8n, Postgres, ollama-cpu, Open WebUI, Flowise, Langflow,
# all MCP sidecars, the gateway) has NO profile and ALWAYS runs. Profiles are
# strictly OPT-IN, comma-separated. Real profiles:
#   gpu-nvidia  → GPU Ollama instead of CPU (run one Ollama, not both)
#   exercises   → the "Build Your Own MCP" IPS/CVE sidecar
#   policypilot → the PolicyPilot MCP sidecar (needs its prebuilt image)
# 'cpu' is kept for backwards-compat but matches nothing (harmless no-op); there
# is no 'true' profile. Example to add the exercise: COMPOSE_PROFILES=exercises
COMPOSE_PROFILES=cpu

# Deploy Flowise (LLM orchestration UI)
DEPLOY_FLOWISE=false

# Deploy Langflow (AI flow builder)
DEPLOY_LANGFLOW=false



