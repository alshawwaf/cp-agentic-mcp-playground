# ---------------- Postgres ----------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n
POSTGRES_PORT=5432

# ---------------- n8n ----------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_string
N8N_USER_MANAGEMENT_JWT_SECRET=change_me_to_a_random_secret

# admin/owner (the one we POST in provision)
N8N_ADMIN_EMAIL=admin@example.com
N8N_ADMIN_FIRST_NAME=Admin
N8N_ADMIN_LAST_NAME=User
N8N_ADMIN_PASSWORD=change_me

# basic auth (MUST match provisioner)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678/
N8N_PUSH_BACKEND=websocket

# ---------------- Ollama ----------------
OLLAMA_PORT=11434
OLLAMA_HOST=localhost
OLLAMA_KEEP_ALIVE=-1

# ---------------- Langflow / Flowise / Open-WebUI ----------------
LANGFLOW_PORT=7860
FLOWISE_PORT=3001
OPEN_WEBUI_PORT=3000
# Langflow auth: true = no-login demo mode; false (default) = login required.
LANGFLOW_AUTO_LOGIN=false


# Documentation MCP creds
DOC_CLIENT_ID=
DOC_SECRET_KEY=
DOC_REGION=EU   # one of: EU, US, STG, Local


# SMS MCP Credentials
# MANAGEMENT_HOST must be reachable FROM THIS DOCKER HOST. For a CloudShare lab
# use the SMS adapter's CloudShare PUBLIC IP (Inbound Access: Public IP) — the
# internal lab IP (10.1.1.x) is not routable from outside the environment. Also
# make sure the SMS routes replies back out the CloudShare gateway (see
# docs/guides/MCP_Gateway_Agent_Guide.md, "Lab connectivity").
MANAGEMENT_HOST=
MANAGEMENT_API_KEY=
TE_API_KEY=
REPUTATION_API_KEY=
SPARK_MGMT_CLIENT_ID=
SPARK_MGMT_SECRET_KEY=
SPARK_MGMT_REGION=US
SPARK_MGMT_INFINITY_PORTAL_URL=https://cloudinfra-gw-us.portal.checkpoint.com/auth/external
HARMONY_SASE_API_KEY=
HARMONY_SASE_MANAGEMENT_HOST=
HARMONY_SASE_REGION=

CPINFO_LOG_LEVEL=info

# ---------------- Exercise: Build Your Own MCP Server (opt-in) ----------------
# Infinity Portal API key for the IPS/CVE exercise sidecar (profile: exercises).
# See docs/guides/Build_Your_Own_MCP_Exercise.md.
IPS_CLIENT_ID=
IPS_ACCESS_KEY=

# ---------------- MCP Gateway (pilot) ----------------
# Stable Bearer token the Docker MCP Gateway requires from clients
# (Authorization: Bearer <token>). Pinning it keeps the provisioned n8n
# credential valid across redeploys; leaving it unset here falls back to the
# compose default used by the training credential. Override for real deployments.
MCP_GATEWAY_TOKEN=cp-mcp-gateway-training-token

# ---------------- AI-Infra-Guard (AI Red Teaming) ----------------
AIG_PORT=8088
# LLM for MCP scanning & jailbreak eval (defaults to local Ollama)
AIG_LLM_API_KEY=ollama
AIG_LLM_BASE_URL=http://ollama-cpu:11434/v1
AIG_LLM_MODEL=huihui_ai/deepseek-r1-abliterated:latest

# ---------------- Optional Services ----------------
# Enable optional services by setting these to true.
# COMPOSE_PROFILES must be set to 'true' for these toggles to work.
COMPOSE_PROFILES=true,cpu

# Deploy Flowise (LLM orchestration UI)
DEPLOY_FLOWISE=false

# Deploy Langflow (AI flow builder)
DEPLOY_LANGFLOW=false



