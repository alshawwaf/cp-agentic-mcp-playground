        "inputs": {
          "requestsPostUrl": "https://idp.{{DOMAIN}}/scim/v2/Users",
          "requestsPostName": "SCIM_Create_User",
          "requestsPostDescription": "Provision (create) a NEW user in the Identity Provider via SCIM 2.0. Provide userName (the user's email), displayName, name {givenName, familyName}, and emails [{value, primary}]. Only call once you have a real email, first name and last name.",
          "requestsPostHeaders": "{\n    \"Authorization\": \"Bearer __IDP_SCIM_TOKEN__\",\n    \"Content-Type\": \"application/scim+json\"\n}",
          "requestPostBody": "{\n    \"schemas\": [\n        \"urn:ietf:params:scim:schemas:core:2.0:User\"\n    ],\n    \"active\": true\n}",
          "requestsPostBodySchema": "{\n    \"userName\": {\n        \"type\": \"string\",\n        \"required\": true,\n        \"description\": \"The new user's login / email address, used as the SCIM userName (e.g. jane.doe@example.com).\"\n    },\n    \"displayName\": {\n        \"type\": \"string\",\n        \"required\": true,\n        \"description\": \"The user's full display name, e.g. 'Jane Doe'.\"\n    },\n    \"name\": {\n        \"type\": \"object\",\n        \"required\": true,\n        \"description\": \"Object with the given and family name, exactly: {\\\"givenName\\\": \\\"Jane\\\", \\\"familyName\\\": \\\"Doe\\\"}.\"\n    },\n    \"emails\": {\n        \"type\": \"array\",\n        \"required\": true,\n        \"description\": \"Array with the primary email, exactly: [{\\\"value\\\": \\\"jane.doe@example.com\\\", \\\"primary\\\": true}].\"\n    }\n}",
          "requestsPostMaxOutputLength": "2000"
        },
        "outputAnchors": [
