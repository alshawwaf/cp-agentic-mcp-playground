        "inputs": {
          "requestsGetUrl": "https://idp.{{DOMAIN}}/scim/v2/Users",
          "requestsGetName": "SCIM_List_Users",
          "requestsGetDescription": "List or search existing users in the Identity Provider via SCIM 2.0. Optionally pass a SCIM `filter` (e.g. userName eq \"jane.doe@example.com\"), plus startIndex/count for paging. Use this to check whether a user already exists or to find a user.",
          "requestsGetHeaders": "{\n    \"Authorization\": \"Bearer __IDP_SCIM_TOKEN__\",\n    \"Accept\": \"application/scim+json\"\n}",
          "requestsGetQueryParamsSchema": "{\n    \"filter\": {\n        \"type\": \"string\",\n        \"in\": \"query\",\n        \"description\": \"SCIM filter expression to search users, e.g. userName eq \\\"jane.doe@example.com\\\" or active eq true. Omit to list all.\"\n    },\n    \"startIndex\": {\n        \"type\": \"number\",\n        \"in\": \"query\",\n        \"description\": \"1-based index of the first result to return (paging).\"\n    },\n    \"count\": {\n        \"type\": \"number\",\n        \"in\": \"query\",\n        \"description\": \"Maximum number of users to return.\"\n    }\n}",
          "requestsGetMaxOutputLength": "2000"
