            "display": true
          }
        ],
        "inputAnchors": [],
        "inputs": {
          "mcpServerConfig": "{\n    \"url\": \"http://mcp-gateway:8080/mcp\",\n    \"headers\": {\n        \"Authorization\": \"Bearer __MCP_GATEWAY_TOKEN__\"\n    }\n}",
          "mcpActions": "[\"show_hosts\", \"show_networks\", \"show_gateways_and_servers\", \"show_access_rulebase\", \"show_access_layers\", \"show_objects\", \"show_object\", \"show_services_tcp\", \"show_groups\", \"show_packages\", \"where_used\", \"show_nat_rulebase\"]"
