            "display": true
          }
        ],
        "inputAnchors": [],
        "inputs": {
          "mcpServerConfig": "{\n    \"url\": \"http://mcp-gateway:8080/mcp\",\n    \"headers\": {\n        \"Authorization\": \"Bearer __MCP_GATEWAY_TOKEN__\"\n    }\n}",
          "mcpActions": "[\"manage_gaia_credentials\", \"show_arp\", \"show_bgp_groups\", \"show_bgp_paths\", \"show_bgp_peers\", \"show_bgp_routemaps\", \"show_bgp_routes_in\", \"show_bgp_routes_out\", \"show_bgp_summary\", \"show_bootp_interfaces\", \"show_configuration_bgp\", \"show_date_time\", \"show_dhcp\", \"show_dhcp6\", \"show_dns\", \"show_dns_domains\", \"show_igmp_groups\", \"show_igmp_interfaces\", \"show_inbound_route_filter_bgp_policy\", \"show_inbound_route_filter_ospf\", \"show_inbound_route_filter_rip\", \"show_ipv6\", \"show_ipv6_pim_summary\", \"show_isis_info\", \"show_nat_pools\", \"show_ospf_summary\", \"show_pbr_rules\", \"show_pbr_tables\", \"show_pim_summary\", \"show_proxy\"]"
