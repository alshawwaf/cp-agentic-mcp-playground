            "hideCodeExecute": true,
            "hint": {
              "label": "How to use",
              "value": "Remote MCP over streamable HTTP. Bearer auth in headers."
            },
            "placeholder": "{\n    \"url\": \"http://host:port/mcp\"\n}",
            "id": "customMCP_0-input-mcpServerConfig-code",
            "display": true
          },
          {
            "label": "Available Actions",
            "name": "mcpActions",
