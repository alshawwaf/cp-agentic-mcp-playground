        "public": true,
        "initialMessages": "👋 I'm the **Check Point Documentation** AI agent — I search official Check Point documentation and SecureKnowledge and answer with citations.\n\n⚡ Every call rides through the **Docker MCP Gateway** — one endpoint, Bearer auth, the whole Check Point MCP fleet.\n\n**Try one of these:**\n• How do I enable Identity Awareness on R82?\n• Find the SK about the Gaia API",
        "options": {
          "responseMode": "lastNode",
          "title": "CP Documentation — AI Agent (Gateway)",
          "subtitle": "Check Point docs & SKs, answered with sources.",
          "inputPlaceholder": "e.g. How do I enable Identity Awareness on R82?"
        }
      },
      "id": "6385dd5c-7887-4a23-8cc6-65167bbc4f96",
