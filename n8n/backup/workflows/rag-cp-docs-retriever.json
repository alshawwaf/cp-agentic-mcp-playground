      "name": "Search cp_docs (Qdrant)"
    },
    {
      "parameters": {
        "jsCode": "const hits = ($input.first().json.result) || [];\nif (!Array.isArray(hits) || hits.length === 0) {\n  return [{ json: { response: \"No matching snippets were found in the 'cp_docs' Qdrant collection. It may be empty — run the one-shot 'rag-ingest' job (see integrations/rag-cp-docs/INTEGRATION.md).\" } }];\n}\nconst blocks = hits.map((h, i) => {\n  const p = h.payload || {};\n  const score = (typeof h.score === 'number') ? h.score.toFixed(3) : 'n/a';\n  const title = p.title || p.source || 'snippet';\n  return `### Result ${i + 1} — ${title}\\n(source: ${p.source || 'unknown'} · score: ${score})\\n\\n${p.text || ''}`;\n});\nconst response = `Retrieved ${hits.length} snippet(s) from the 'cp_docs' collection. Answer ONLY from these snippets and cite each \\`source\\` filename you use.\\n\\n` + blocks.join('\\n\\n');\nreturn [{ json: { response } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
