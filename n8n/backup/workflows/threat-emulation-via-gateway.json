      "parameters": {
        "public": true,
        "initialMessages": "👋 I'm the **Check Point Threat Emulation** AI agent — I submit files to the Check Point sandbox and explain the verdicts.\n\n⚡ Every call rides through the **Docker MCP Gateway** — one endpoint, Bearer auth, the whole Check Point MCP fleet.\n\n**Try one of these:**\n• Check this hash for a verdict: <sha256>\n• What file types can you emulate?",
        "options": {
          "responseMode": "lastNode",
          "title": "CP Threat Emulation — AI Agent (Gateway)",
          "subtitle": "Sandbox verdicts for files & hashes.",
          "inputPlaceholder": "e.g. Check this hash for a verdict: <sha256>"
        }
      },
      "id": "a8ba8d3c-2886-4c9b-90ab-4a6236006c8b",
